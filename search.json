---
layout: null
---
[
  {% comment %}— POSTS —{% endcomment %}
  {% for post in site.posts %}
  {% assign post_author_key = post.author | default: "editorial" %}
  {% assign post_author = site.data.authors[post_author_key] %}
  {
    "type": "post",
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: "%B %-d, %Y" | jsonify }},
    "date_iso": {{ post.date | date_to_xmlschema | jsonify }},
    "excerpt": {{ post.description | default: post.excerpt | strip_html | truncatewords: 40 | jsonify }},
    "categories": {{ post.categories | jsonify }},
    "tags": {{ post.tags | jsonify }},
    "author_key": {{ post_author_key | jsonify }},
    "author": {{ post_author.display_name | default: post_author_key | jsonify }},
    "image": {{ post.image | default: "" | jsonify }},
    "content": {{ post.content | strip_html | normalize_whitespace | truncatewords: 80 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}

  {% comment %}— PAGES (non-policy, non-system) —{% endcomment %}
  {% assign searchable_pages = site.pages | where_exp: "p", "p.title != nil" | where_exp: "p", "p.sitemap != false" | where_exp: "p", "p.layout != 'category'" | where_exp: "p", "p.layout != 'tag'" | where_exp: "p", "p.layout != 'author'" %}
  {% for page in searchable_pages %}
  {% assign page_url = page.url | relative_url %}
  {% unless page_url contains '/feed' or page_url contains 'search.json' or page_url == '/search/' %}
  ,{
    "type": "page",
    "title": {{ page.title | jsonify }},
    "url": {{ page_url | jsonify }},
    "date": "",
    "date_iso": "",
    "excerpt": {{ page.description | default: page.content | strip_html | normalize_whitespace | truncatewords: 40 | jsonify }},
    "categories": [],
    "tags": [],
    "author_key": "",
    "author": "",
    "image": "",
    "content": {{ page.content | strip_html | normalize_whitespace | truncatewords: 80 | jsonify }}
  }
  {% endunless %}
  {% endfor %}

  {% comment %}— AUTHORS —{% endcomment %}
  {% for author_hash in site.data.authors %}
  {% assign author_key = author_hash[0] %}
  {% assign author = author_hash[1] %}
  ,{
    "type": "author",
    "title": {{ author.display_name | jsonify }},
    "url": {{ '/author/' | append: author.name | relative_url | jsonify }},
    "date": "",
    "date_iso": "",
    "excerpt": {{ author.bio | default: "" | jsonify }},
    "categories": [],
    "tags": [],
    "author_key": {{ author_key | jsonify }},
    "author": {{ author.role | default: "" | jsonify }},
    "image": {{ author.avatar | default: "" | jsonify }},
    "content": {{ author.bio | default: "" | jsonify }}
  }
  {% endfor %}
]
